<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===================== VISTA FORMULARIO ===================== -->
    <record id="view_empleado_form" model="ir.ui.view">
        <field name="name">control.empleado.form</field>
        <field name="model">control.empleado</field>
        <field name="arch" type="xml">
            <form string="Empleado">
                <sheet>
                    <div class="oe_title">
                        <label for="nombre" string="Nombre del Empleado"/>
                        <h1>
                            <field name="nombre" placeholder="Nombre completo..."/>
                        </h1>
                    </div>

                    <group>
                        <group string="Datos Profesionales">
                            <field name="puesto"/>
                            <field name="departamento"/>
                            <field name="fecha_alta"/>
                            <field name="estado" widget="badge"
                                   decoration-success="estado == 'activo'"
                                   decoration-warning="estado == 'vacaciones'"
                                   decoration-danger="estado == 'baja'"/>
                        </group>
                        <group string="Contacto">
                            <field name="telefono"/>
                            <field name="email" widget="email"/>
                        </group>
                    </group>

                    <group string="Notas">
                        <field name="notas" nolabel="1" placeholder="Añadir notas sobre el empleado..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ===================== VISTA LISTA ===================== -->
    <record id="view_empleado_list" model="ir.ui.view">
        <field name="name">control.empleado.list</field>
        <field name="model">control.empleado</field>
        <field name="arch" type="xml">
            <list string="Empleados" decoration-danger="estado == 'baja'" decoration-warning="estado == 'vacaciones'">
                <field name="nombre"/>
                <field name="puesto"/>
                <field name="departamento"/>
                <field name="telefono"/>
                <field name="email"/>
                <field name="fecha_alta"/>
                <field name="estado" widget="badge"
                       decoration-success="estado == 'activo'"
                       decoration-warning="estado == 'vacaciones'"
                       decoration-danger="estado == 'baja'"/>
            </list>
        </field>
    </record>

    <!-- ===================== ACCION ===================== -->
    <record id="action_empleado" model="ir.actions.act_window">
        <field name="name">Empleados</field>
        <field name="res_model">control.empleado</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                ¡Añade tu primer empleado!
            </p>
            <p>
                Registra aquí todos los empleados de la empresa con sus datos principales.
            </p>
        </field>
    </record>

</odoo>
